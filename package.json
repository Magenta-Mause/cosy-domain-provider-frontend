    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.1.1",
    "orval": "^7.21.0",
    "postcss": "^8.5.13",
    "tailwindcss": "^3.4.19",
