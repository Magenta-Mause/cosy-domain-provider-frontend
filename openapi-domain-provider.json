      "patch": {
        "tags": ["Admin"],
        "summary": "Rename a subdomain label",
        "operationId": "relabelSubdomain",
        "parameters": [
          {
            "name": "X-Admin-Key",
            "in": "header",
            "description": "Admin secret key",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "uuid",
            "in": "path",
            "description": "Subdomain UUID",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdminSubdomainRelabelDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Subdomain relabeled",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/AdminSubdomainDto" }
              }
            }
          },
          "400": {
