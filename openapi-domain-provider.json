    "/api/v1/auth/token": {
      "get": {
        "tags": ["Authorization"],
        "summary": "Exchange refresh token cookie for a short-lived identity token",
        "operationId": "fetchToken",
        "parameters": [
          {
            "name": "refreshToken",
            "in": "cookie",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Identity token returned",
            "content": { "*/*": { "schema": { "type": "string" } } }
          },
          "400": {
            "description": "Missing or invalid refresh token cookie",
            "content": { "*/*": { "schema": { "type": "string" } } }
          }
        }
      }
    },
    "/api/v1/auth/oauth/{provider}/callback": {
      "get": {
        "tags": ["OAuth"],
        "summary": "Handle OAuth2 callback",
        "description": "Exchanges the authorization code for a token, resolves or creates the local user, and sets the refresh token cookie. Redirects to the frontend on success or failure.",
        "operationId": "callback",
        "parameters": [
          {
            "name": "provider",
            "in": "path",
            "description": "OAuth provider name (google, github, discord)",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "code",
            "in": "query",
            "description": "Authorization code returned by the provider",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "state",
            "in": "query",
            "description": "State parameter for CSRF validation",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect to frontend (dashboard on success, /login?oauthError=true on failure, including upstream OAuth errors)"
          },
          "400": {
            "description": "Invalid or expired state / unknown provider (ResponseStatusException propagated)"
          },
          "502": {
            "description": "Token exchange or user-info fetch failed (ResponseStatusException propagated)"
          }
        }
      }
    },
    "/api/v1/auth/oauth/{provider}/authorize": {
      "get": {
        "tags": ["OAuth"],
        "summary": "Initiate OAuth2 authorization flow",
        "description": "Redirects the user to the provider's authorization page. Supported providers: google, github, discord.",
        "operationId": "authorize",
        "parameters": [
          {
            "name": "provider",
            "in": "path",
            "description": "OAuth provider name (google, github, discord)",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "302": { "description": "Redirect to provider authorization URL" },
          "400": { "description": "Unknown provider" }
        }
      }
    },
    "/api/v1/admin/users": {
      "get": {
        "tags": ["Admin"],
