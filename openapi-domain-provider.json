{
  "openapi": "3.1.0",
  "info": { "title": "OpenAPI definition", "version": "v0" },
  "servers": [
    { "url": "http://localhost:8080", "description": "Generated server url" }
  ],
  "tags": [
    { "name": "User", "description": "User management (admin)" },
    {
      "name": "Subdomain",
      "description": "Subdomain creation and management for the authenticated user"
    },
    {
      "name": "OAuth",
      "description": "OAuth2 social login (Google, GitHub, Discord)"
    },
    {
      "name": "Admin",
      "description": "Admin-only endpoints protected by a shared secret key"
    },
    {
      "name": "Billing",
      "description": "Stripe billing portal and subscription checkout"
    },
    {
      "name": "Authorization",
      "description": "Authentication, registration, and account management"
    },
    {
      "name": "Stripe Webhook",
      "description": "Stripe event webhook consumer (internal — not for client use)"
    }
  ],
  "paths": {
    "/api/v1/subdomain/{uuid}": {
      "get": {
        "tags": ["Subdomain"],
        "summary": "Get a specific subdomain owned by the authenticated user",
        "operationId": "getSubdomain",
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "description": "Subdomain UUID",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Subdomain returned",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/SubdomainDto" }
              }
            }
          },
          "403": {
            "description": "Not owned by the current user",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/SubdomainDto" }
              }
            }
          },
          "404": {
            "description": "Subdomain not found",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/SubdomainDto" }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["Subdomain"],
        "summary": "Update the target IP of a subdomain",
        "operationId": "updateSubdomain",
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "description": "Subdomain UUID",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SubdomainUpdateDto" }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Subdomain updated",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/SubdomainDto" }
              }
            }
          },
          "403": {
            "description": "Not owned by the current user",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/SubdomainDto" }
              }
            }
          },
          "404": {
            "description": "Subdomain not found",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/SubdomainDto" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Subdomain"],
        "summary": "Delete a subdomain and its DNS record",
        "operationId": "deleteSubdomain",
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "description": "Subdomain UUID",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "204": { "description": "Subdomain deleted" },
          "403": { "description": "Not owned by the current user" },
          "404": { "description": "Subdomain not found" }
        }
      }
    },
    "/api/v1/admin/subdomains/{uuid}": {
      "get": {
        "tags": ["Admin"],
        "summary": "Get a single subdomain by UUID",
        "operationId": "getSubdomain_1",
        "parameters": [
          {
            "name": "X-Admin-Key",
            "in": "header",
            "description": "Admin secret key",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "uuid",
            "in": "path",
            "description": "Subdomain UUID",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Subdomain returned",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/AdminSubdomainDto" }
              }
            }
          },
          "401": {
            "description": "Invalid admin key",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/AdminSubdomainDto" }
              }
