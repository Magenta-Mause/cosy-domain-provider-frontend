            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SubdomainUpdateDto" }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Subdomain updated",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/AdminSubdomainDto" }
              }
            }
          },
          "400": {
            "description": "Invalid request body",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/AdminSubdomainDto" }
              }
            }
          },
          "401": {
            "description": "Invalid admin key",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/AdminSubdomainDto" }
              }
            }
          },
          "404": {
            "description": "Subdomain not found",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/AdminSubdomainDto" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Admin"],
        "summary": "Delete a subdomain",
        "operationId": "deleteSubdomain_1",
        "parameters": [
          {
            "name": "X-Admin-Key",
            "in": "header",
            "description": "Admin secret key",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "uuid",
            "in": "path",
            "description": "Subdomain UUID",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "204": { "description": "Subdomain deleted" },
          "401": { "description": "Invalid admin key" },
          "404": { "description": "Subdomain not found" }
        }
      }
    },
    "/api/v1/user": {
      "get": {
        "tags": ["User"],
        "summary": "List all users",
        "operationId": "getAllUsers",
        "responses": {
          "200": {
            "description": "User list returned",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/UserDto" }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["User"],
        "summary": "Create a new user and send verification email",
        "operationId": "createUser",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UserCreationDto" }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "User created",
            "content": {
              "*/*": { "schema": { "$ref": "#/components/schemas/UserDto" } }
            }
          },
          "409": {
            "description": "Email already in use",
            "content": {
              "*/*": { "schema": { "$ref": "#/components/schemas/UserDto" } }
            }
          }
        }
      },
      "delete": {
        "tags": ["User"],
        "summary": "Delete the authenticated user and all their subdomains",
        "operationId": "deleteUser",
        "responses": { "204": { "description": "User deleted" } }
      },
      "patch": {
        "tags": ["User"],
        "summary": "Update username or password of the authenticated user",
        "operationId": "updateUser",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateUserDto" }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "User updated",
            "content": {
              "*/*": { "schema": { "$ref": "#/components/schemas/UserDto" } }
            }
          },
          "401": {
            "description": "Current password incorrect",
            "content": {
              "*/*": { "schema": { "$ref": "#/components/schemas/UserDto" } }
            }
          }
        }
      }
    },
    "/api/v1/subdomain": {
      "get": {
        "tags": ["Subdomain"],
        "summary": "List all subdomains owned by the authenticated user",
        "operationId": "listMySubdomains",
        "responses": {
          "200": {
            "description": "Subdomain list returned",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/SubdomainDto" }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Subdomain"],
        "summary": "Create a new subdomain",
        "operationId": "createSubdomain",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SubdomainCreationDto" }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Subdomain created",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/SubdomainDto" }
              }
            }
          },
          "400": {
            "description": "Label reserved or invalid",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/SubdomainDto" }
              }
            }
          },
          "409": {
            "description": "Label already taken",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/SubdomainDto" }
              }
            }
          },
          "429": {
            "description": "Subdomain limit reached for this plan",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/SubdomainDto" }
              }
            }
          }
        }
      }
    },
    "/api/v1/stripe-events": {
      "post": {
        "tags": ["Stripe Webhook"],
        "summary": "Consume a Stripe webhook event",
        "description": "Verifies the Stripe-Signature header and processes the event.",
        "operationId": "consumeEvent",
        "parameters": [
          {
            "name": "Stripe-Signature",
            "in": "header",
            "description": "Stripe webhook signature header",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "content": { "application/json": { "schema": { "type": "string" } } },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Event processed",
            "content": { "*/*": { "schema": { "type": "string" } } }
          },
          "400": {
            "description": "Invalid Stripe signature",
            "content": { "*/*": { "schema": { "type": "string" } } }
          }
        }
      }
    },
    "/api/v1/billing/checkout": {
      "post": {
        "tags": ["Billing"],
        "summary": "Get Stripe checkout URL to upgrade to Plus",
        "description": "Requires a verified email address.",
        "operationId": "getCheckoutUrl",
        "responses": {
          "200": {
            "description": "Checkout URL returned",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BillingPortalResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Not authenticated",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BillingPortalResponseDto"
                }
              }
            }
          },
          "403": {
            "description": "Email not verified",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BillingPortalResponseDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/verify": {
      "post": {
        "tags": ["Authorization"],
        "summary": "Verify email address with the code sent on registration",
        "operationId": "verifyEmail",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EmailVerificationDto" }
            }
          },
          "required": true
        },
        "responses": {
          "204": { "description": "Email verified" },
          "401": { "description": "Invalid or expired verification code" }
        }
      }
    },
    "/api/v1/auth/set-password": {
      "post": {
        "tags": ["Authorization"],
        "summary": "Set initial password for OAuth-created accounts",
        "description": "Only available when needsPasswordSetup is true (OAuth accounts without a password).",
        "operationId": "setPassword",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SetPasswordDto" }
            }
          },
          "required": true
        },
        "responses": {
          "204": { "description": "Password set" },
          "401": { "description": "Not authenticated" },
          "409": { "description": "Password already set" }
        }
      }
    },
    "/api/v1/auth/reset-password": {
      "post": {
        "tags": ["Authorization"],
        "summary": "Complete password reset using token from email",
        "operationId": "resetPassword",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ResetPasswordDto" }
            }
          },
          "required": true
        },
        "responses": {
          "204": { "description": "Password reset successfully" },
          "400": { "description": "Invalid or expired reset token" }
        }
      }
    },
    "/api/v1/auth/resend-verification": {
      "post": {
        "tags": ["Authorization"],
        "summary": "Resend email verification code",
        "operationId": "resendVerification",
        "responses": {
          "204": { "description": "Verification email sent" },
          "409": { "description": "Email already verified" }
        }
      }
    },
    "/api/v1/auth/register": {
      "post": {
        "tags": ["Authorization"],
        "summary": "Register a new user account",
        "operationId": "register",
        "parameters": [
          {
            "name": "tokenMode",
            "in": "query",
            "description": "COOKIE sets httpOnly cookie, DIRECT returns token in body",
            "required": false,
            "schema": {
              "type": "string",
              "default": "COOKIE",
              "enum": ["COOKIE", "DIRECT"]
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UserCreationDto" }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Account created",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/LoginResponseDto" }
              }
            }
          },
          "409": {
            "description": "Email already in use",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/LoginResponseDto" }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/logout": {
      "post": {
        "tags": ["Authorization"],
        "summary": "Logout — clears the refresh token cookie",
        "operationId": "logout",
        "responses": { "204": { "description": "Logged out" } }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "tags": ["Authorization"],
        "summary": "Login with email and password",
        "operationId": "login",
        "parameters": [
          {
            "name": "tokenMode",
            "in": "query",
            "description": "COOKIE sets httpOnly cookie, DIRECT returns token in body",
            "required": false,
            "schema": {
              "type": "string",
              "default": "COOKIE",
              "enum": ["COOKIE", "DIRECT"]
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginDto" }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/LoginResponseDto" }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/LoginResponseDto" }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/forgot-password": {
      "post": {
        "tags": ["Authorization"],
        "summary": "Initiate password reset — sends reset link to email",
        "operationId": "forgotPassword",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ForgotPasswordDto" }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "Reset email sent (always, to avoid enumeration)"
          }
        }
      }
    },
