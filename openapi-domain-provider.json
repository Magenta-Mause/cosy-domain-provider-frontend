  "components": {
    "schemas": {
      "SubdomainUpdateDto": {
        "type": "object",
        "properties": {
          "targetIp": {
            "type": "string",
            "minLength": 1,
            "pattern": "^((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$"
          }
        },
        "required": ["targetIp"]
      },
      "SubdomainDto": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string" },
          "label": { "type": "string" },
          "fqdn": { "type": "string" },
          "targetIp": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["PENDING", "ACTIVE", "FAILED"]
          },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "UserCreationDto": {
        "type": "object",
        "properties": {
          "username": { "type": "string", "maxLength": 20, "minLength": 3 },
          "email": { "type": "string", "format": "email", "minLength": 1 },
          "password": {
            "type": "string",
            "maxLength": 2147483647,
            "minLength": 8
          }
        },
        "required": ["email"]
      },
      "UserDto": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string" },
          "username": { "type": "string" },
          "email": { "type": "string" },
          "verified": { "type": "boolean" }
        }
      },
      "SubdomainCreationDto": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "maxLength": 63,
            "minLength": 1,
            "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$"
          },
          "targetIp": {
            "type": "string",
            "minLength": 1,
            "pattern": "^((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$"
          }
        },
        "required": ["label", "targetIp"]
      },
      "EmailVerificationDto": {
        "type": "object",
        "properties": { "token": { "type": "string" } }
      },
      "LoginResponseDto": {
        "type": "object",
        "properties": { "refreshToken": { "type": "string" } }
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "minLength": 1 },
          "password": { "type": "string", "minLength": 1 }
        },
        "required": ["email", "password"]
      },
      "DnsEntry": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "ttl": { "type": "integer", "format": "int64" },
          "values": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
